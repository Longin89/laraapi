# ============================================================================
# LARAVEL APPLICATION CONFIGURATION
# ============================================================================

# Application Name
APP_NAME="Test Laravel API"

# Application Environment (local, development, testing, production)
# local: максимальная отладка, все ошибки видны
# development: промежуточный режим для разработки
# production: минимум логирования, скрытие ошибок от пользователя
APP_ENV=local

# Application Debug Mode
# true: показывает детальные ошибки (ТОЛЬКО для local/development)
# false: скрывает ошибки (ОБЯЗАТЕЛЬНО для production)
APP_DEBUG=true

# Application URL (должна совпадать с доменом, на котором запущено приложение)
# local: http://localhost:8000
# production: https://example.com
APP_URL=http://localhost

# Application Timezone
APP_TIMEZONE=Europe/Moscow

# Encryption Key (сгенерируется автоматически через php artisan key:generate)
APP_KEY=

# Encryption Cipher (rijndael-256 или AES-256-GCM)
APP_CIPHER=AES-256-GCM


# ============================================================================
# HTTPS / SSL & SECURITY CONFIGURATION
# ============================================================================

# Force HTTPS для всех URL
# true: все URL генерируются как https:// (нужно включить на production!)
# false: используется текущий протокол (http или https)
# ВАЖНО: если стоит true, убедитесь что nginx/load balancer правильно передает HTTPS
FORCE_HTTPS=false

# Trust specific proxies for HTTPS detection
# Используется при работе за nginx/Apache proxy или load balancer
# '*' - доверять всем прокси (для Docker контейнеров)
# Перечисление IP - доверять только конкретным IP адресам
TRUST_PROXIES=*

# Secure cookies over HTTPS (для сессий и CSRF токенов)
# true: cookie передаются только по HTTPS
# false: cookie передаются по HTTP (ТОЛЬКО для local/development!)
SESSION_SECURE_COOKIES=false

# SameSite для cookies (Strict, Lax, None)
# Strict: максимальная безопасность, но может сломать некоторые функции
# Lax: баланс между безопасностью и функциональностью (рекомендуется)
# None: совместимость, но требует Secure flag
SESSION_SAME_SITE=Lax


# ============================================================================
# DATABASE CONFIGURATION (DockerКонтейнер MySQL)
# ============================================================================

# Default Database Connection
# Поддерживаемые: mysql, mariadb, pgsql, sqlite, sqlsrv
DB_CONNECTION=mysql

# Database Host
DB_HOST=mysql

# Database Port
DB_PORT=3306

# Database Name
DB_DATABASE=laravel_db

# Database Username
DB_USERNAME=laravel_user

# Database Password
DB_PASSWORD=password_123

# Database Root Password (для первначальной настройки Docker контейнера)
DB_ROOT_PASSWORD=password_123


# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Cache Driver
# database: сохранять в БД (медленнее, но работает везде)
# redis: использовать Redis (быстрее, требует Redis сервиса)
# file: файловая система
# memcached: Memcached сервис
# array: только в памяти (для тестирования)
CACHE_STORE=database

# Redis Cache Configuration (если CACHE_STORE=redis)
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_STORE=redis
CACHE_DRIVER=redis


# ============================================================================
# SESSION CONFIGURATION
# ============================================================================

# Session Driver
# database: сохранять сессии в БД (рекомендуется для Livewire)
# file: файловая система
# redis: Redis (требует Redis сервиса)
# cookie: в cookies (небезопасно для больших данных)
SESSION_DRIVER=database

# Session Table (для database driver)
SESSION_TABLE=sessions

# Session Lifetime in Minutes
SESSION_LIFETIME=120


# ============================================================================
# QUEUE CONFIGURATION
# ============================================================================

# Queue Connection
# sync: обработка задач синхронно (для local, медленно)
# database: использовать БД для очереди
# redis: использовать Redis (быстрее)
# rabbitmq: RabbitMQ сервис (продвинуто)
QUEUE_CONNECTION=sync


# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Logging Channel
# single: один файл (storage/logs/laravel.log)
# stack: несколько драйверов одновременно
# daily: ежедневные файлы с ротацией
# slack: отправка серьезных ошибок в Slack
# syslog: системный логирование
LOG_CHANNEL=stack

# Logging Level
# emergency, alert, critical, error, warning, notice, info, debug
# Все ошибки уровня и выше будут залогированы
LOG_LEVEL=debug


# ============================================================================
# FILESYSTEM & AWS CONFIGURATION
# ============================================================================

# Filesystem Driver
# local: локальная файловая система (storage/app)
# s3: AWS S3
FILESYSTEM_DISK=local

# AWS Configuration (если FILESYSTEM_DISK=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=


# ============================================================================
# OPTIONAL: REDIS & CACHE ADVANCED
# ============================================================================

# Redis Configuration
REDIS_CONNECTION=redis

# Cache TTL (Time to Live) - как долго хранить кэш по умолчанию
# 86400 = 1 день (секунды)
CACHE_DEFAULT_TTL=3600

